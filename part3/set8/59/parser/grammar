%filenames parser

%scanner ../scanner/scanner.h
%token-path ../scanner/tokens.h

%token INT STRING DOUBLE QUIT

%polymorphic INT: int; STRING: std::string; DOUBLE: double;

%%

lines:
    lines '\n' line
|
    // empty
;

line:
    INT
    {
        showInt($1);
    }
|
    STRING
    {
        showString($1);
    }
|
    DOUBLE 
    {
        showDouble($1);
    }
|
    QUIT
    {
        quit();
    }
|
    '\n'
;
